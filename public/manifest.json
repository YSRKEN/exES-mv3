{
  "name": "exES",
  "manifest_version": 3,
  "version": "1.1.0",
  "description": "A chrome extention in ErogameScape. This allow you to overview price in some website.",
  "icons": {
    "16": "logo16.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://erogamescape.dyndns.org/*"],
      "js": ["content_scripts.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://erogamescape.dyndns.org/*",
    "*://*.amazon.jp/*",
    "*://*.amazon.co.jp/*",
    "*://*.getchu.com/*",
    "*://*.sofmap.com/*",
    "*://*.suruga-ya.jp/*",
    "*://*.dmm.co.jp/*",
    "*://*.dlsite.com/*",
    "*://store.steampowered.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "amazon", "enabled": true, "path": "amazon_rule.json" },
      { "id": "getchu", "enabled": true, "path": "getchu_rule.json" },
      { "id": "sofmap", "enabled": true, "path": "sofmap_rule.json" },
      { "id": "surugaya", "enabled": true, "path": "surugaya_rule.json" },
      { "id": "dlsite", "enabled": true, "path": "dlsite_rule.json" },
      { "id": "fanza", "enabled": true, "path": "fanza_rule.json" }
    ]
  }
}
